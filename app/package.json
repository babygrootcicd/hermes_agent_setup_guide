{
  "name": "hermes-agent-gui",
  "version": "0.1.0",
  "description": "Desktop GUI for Hermes Agent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.hermes.agent.gui",
    "productName": "Hermes Agent",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist"
    ]
  }
}
