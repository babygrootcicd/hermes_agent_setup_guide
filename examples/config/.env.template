# Hermes Agent Environment Variables Template
# Copy to ~/.hermes/.env
# Never commit this file. Keep permissions at 600.

# LLM providers
# GOOGLE_API_KEY=your_google_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
# OPENROUTER_API_KEY=your_openrouter_key_here

# OAuth/device-code token stores are written to ~/.hermes/auth.json
# when using providers like google-gemini-cli, copilot, or codex oauth.

# Messaging gateways
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# DISCORD_BOT_TOKEN=your_discord_bot_token_here
# SLACK_BOT_TOKEN=your_slack_bot_token_here

# Optional integrations
# GITHUB_TOKEN=your_github_token_here
